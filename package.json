{
  "name": "diplopresent-3",
  "private": true,
  "version": "3.1.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others --names API,VITE --prefix-colors yellow,cyan \"npm:dev:api\" \"npm:dev:frontend\"",
    "dev:host": "concurrently --kill-others --names API,VITE --prefix-colors yellow,cyan \"npm:dev:api\" \"npm:dev:frontend:host\"",
    "dev:api": "php -S 127.0.0.1:8080",
    "dev:frontend": "vite",
    "dev:frontend:host": "vite --host 0.0.0.0",
    "build": "vite build && node scripts/prepare-dist.mjs",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.3",
    "lucide-vue-next": "^0.468.0",
    "papaparse": "^5.4.1",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-draggable-plus": "^0.6.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.1.2",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
