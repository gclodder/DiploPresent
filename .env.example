# Kopieer dit bestand naar .env en vul een echte hash in.
# Genereer een hash met:
# php -r "echo password_hash('jouw-wachtwoord', PASSWORD_DEFAULT), PHP_EOL;"

DIPLOPRESENT_ADMIN_PASSWORD_HASH=""
# Optioneel: zet hiermee een eerste gebruikerswachtwoord klaar.
# Daarna kan admin dit via Beheer roteren; de nieuwe hash komt in storage/auth.json.
DIPLOPRESENT_USER_PASSWORD_HASH=""
DIPLOPRESENT_SESSION_NAME="diplopresent_auth"
